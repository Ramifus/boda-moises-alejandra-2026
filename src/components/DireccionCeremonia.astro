<!-- ═══════════════════════════════════════════════════════════ --><!-- ⛪ SECCIÓN: CEREMONIA                                       --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-4 pb-12 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE CEREMONIA - HORIZONTAL -->
        <div class="flex justify-center">
            <div
                class="relative w-full max-w-md sm:max-w-lg md:max-w-xl"
                id="card-ceremonia"
            >
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-ceremonia">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <div
                    class="relative rounded-2xl shadow-xl overflow-hidden"
                    style="background-color: #e8dcc8;"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondorojo.png"
                        alt="Fondo ceremonia"
                        class="absolute inset-0 w-full h-full object-cover opacity-90"
                    />

                    <!-- Contenido de la card - LAYOUT CON TÍTULO EXTENDIDO -->
                    <div
                        class="relative px-4 pt-14 pb-8 sm:px-8 sm:pt-16 sm:pb-10 md:px-10 md:pt-16 md:pb-12 z-10"
                    >
                        <!-- TÍTULO: CEREMONIA RELIGIOSA - OCUPA TODO EL ANCHO -->
                        <div class="mb-2">
                            <h2
                                class="font-great-vibes text-4xl sm:text-4xl md:text-5xl texto-ceremonia text-center"
                                id="titulo-ceremonia"
                            >
                                Ceremonia Religiosa
                            </h2>
                        </div>

                        <!-- CONTENIDO INFERIOR CON ICONO Y TEXTOS -->
                        <div class="flex items-center justify-between gap-4">
                            <!-- LADO IZQUIERDO: ICONO DE IGLESIA -->
                            <div class="flex-shrink-0 ml-4 sm:ml-6 md:ml-8">
                                <div
                                    class="w-24 h-24 sm:w-20 sm:h-20 md:w-24 md:h-24 icono-iglesia-color"
                                >
                                    <img
                                        src="/imagenes/iglesia.png"
                                        alt="Iglesia"
                                        class="w-full h-full object-contain"
                                        id="icono-iglesia"
                                    />
                                </div>
                            </div>

                            <!-- LADO DERECHO: TEXTOS Y BOTÓN -->
                            <div class="flex-1 text-center">
                                <!-- NOMBRE DE LA PARROQUIA -->
                                <div class="mb-2">
                                    <p
                                        class="font-crimson text-xl sm:text-lg md:text-xl texto-ceremonia font-semibold"
                                        id="nombre-parroquia"
                                    >
                                        Iglesia Jesús Nazareno
                                    </p>
                                </div>

                                <!-- DIRECCIÓN -->
                                <div class="mb-2 leading-tight">
                                    <p
                                        class="font-crimson text-xl sm:text-sm md:text-base texto-ceremonia"
                                        id="direccion-parroquia"
                                    >
                                        Parroquia Jesús Nazareno,<br />
                                        entre la calle La Paz<br />
                                        y Ñuflo de Chávez
                                    </p>
                                </div>

                                <!-- HORA -->
                                <div class="mb-4">
                                    <p
                                        class="font-crimson text-xl sm:text-base md:text-lg leading-tight texto-ceremonia font-semibold"
                                        id="hora-ceremonia"
                                    >
                                        Hora: 15:30
                                    </p>
                                </div>

                                <!-- BOTÓN VER UBICACIÓN -->
                                <div class="mt-4">
                                    <a
                                        href="https://maps.app.goo.gl/XkMCPMvSwQCK9b5c7"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-block px-4 py-2 sm:px-6 sm:py-2.5 border-2 rounded-full font-crimson text-base sm:text-sm uppercase tracking-wider transition-all duration-300 btn-ubicacion-ceremonia font-semibold"
                                        id="btn-ubicacion"
                                    >
                                        VER UBICACIÓN
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            console.log("⛪ Iniciando animaciones de ceremonia...");

            // Botón decorativo
            gsap.fromTo(
                "#boton-decorativo-ceremonia",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-ceremonia",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            // 🎯 ANIMACIÓN ELEGANTE DE ENTRADA - TODO AL MISMO TIEMPO
            gsap.fromTo(
                "#card-ceremonia",
                {
                    opacity: 0,
                    scale: 0.85,
                    y: 60,
                    rotationY: -15,
                },
                {
                    opacity: 1,
                    scale: 1,
                    y: 0,
                    rotationY: 0,
                    duration: 1.2,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-ceremonia",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            console.log("⛪✨ ¡Animaciones de ceremonia activadas!");
        });
    }
</script>

