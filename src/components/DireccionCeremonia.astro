    }

    .btn-ubicacion-ceremonia {
        color: #9c8a5a;
        border-color: #b7a671;
    }

    /* Efecto hover en la card */
    #card-ceremonia > div {
        transition: all 0.4s ease;
        transform-style: preserve-3d;
    }

